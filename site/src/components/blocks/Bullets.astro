---
import Inline from './Inline.astro';

interface Props {
  /** `l` = indent level (1-based); `h` = inline text (**bold**, *em*, `code`). */
  items: { l: number; h: string }[];
}

const { items } = Astro.props;
---

<ul class="bullets">
  {
    items.map((it) => (
      <li class:list={[`lvl-${Math.max(1, Math.min(4, it.l))}`]}>
        <Inline text={it.h} />
      </li>
    ))
  }
</ul>

<style>
  .bullets {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .bullets li {
    position: relative;
    padding-left: var(--space-5);
    margin-bottom: var(--space-3);
  }

  .bullets li::before {
    content: "";
    position: absolute;
    left: var(--space-2);
    top: 0.65em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--brand);
  }

  .lvl-2 {
    margin-left: var(--space-5);
  }
  .lvl-3 {
    margin-left: var(--space-8);
  }
  .lvl-4 {
    margin-left: var(--space-12);
  }

  .lvl-2::before,
  .lvl-3::before,
  .lvl-4::before {
    background: var(--gray-500);
  }

  .bullets :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface-muted);
    padding: 0.05em 0.35em;
    border-radius: var(--radius-sm);
  }
</style>
