---
import Icon from '@components/Icon.astro';
import type { IconName } from '@lib/icons';

// A callout container for a worked demo / live example. Body is slotted.
interface Props {
  title?: string;
  icon?: IconName;
}

const { title = 'Demo', icon } = Astro.props;
---

<aside class="demo">
  <p class="demo__label">
    {icon && <Icon name={icon} size={18} />}
    <span>{title}</span>
  </p>
  <div class="demo__body">
    <slot />
  </div>
</aside>

<style>
  .demo {
    margin: var(--space-4) 0;
    border: 1px solid var(--brand);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .demo__label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
    padding: var(--space-2) var(--space-3);
    background: var(--brand);
    color: var(--brand-contrast);
    font-weight: 700;
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .demo__body {
    padding: var(--space-4);
  }
</style>
