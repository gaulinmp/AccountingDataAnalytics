---
import CodeBlock from './CodeBlock.astro';
import Inline from './Inline.astro';

interface Props {
  sql: string;
  /** A clause-by-clause walkthrough of the query. */
  rows: { clause: string; desc: string }[];
}

const { sql, rows } = Astro.props;
---

<div class="sqlwalk">
  <CodeBlock code={sql} lang="sql" />
  <dl class="walk">
    {
      rows.map((r) => (
        <div class="walk__row">
          <dt><code>{r.clause}</code></dt>
          <dd><Inline text={r.desc} /></dd>
        </div>
      ))
    }
  </dl>
</div>

<style>
  .sqlwalk {
    margin: var(--space-4) 0;
  }

  .walk {
    margin: var(--space-3) 0 0;
    display: grid;
    gap: var(--space-2);
  }

  .walk__row {
    display: grid;
    grid-template-columns: minmax(7rem, max-content) 1fr;
    gap: var(--space-3);
    align-items: baseline;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border);
    border-left: 4px solid var(--brand);
    background: var(--surface-muted);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.02);
  }

  .walk__row dt {
    margin: 0;
  }

  .walk__row dt code {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--brand);
  }

  .walk__row dd {
    margin: 0;
    font-size: var(--fs-base);
  }
</style>
