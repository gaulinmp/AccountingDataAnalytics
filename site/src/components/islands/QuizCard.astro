---
// Enhances every static <Quiz> form ([data-quiz]) in place: a Check-answer
// button, correct/incorrect styling, reveal-the-why-after-answering, and
// localStorage persistence keyed by the stable quiz id. Reads correct/why from
// the DOM hooks emitted in Stage 3 — no network.
---

<script>
  import { NS } from '../../lib/deck';
  import { isAnswerCorrect, quizFeedback } from '../../lib/quiz-score';

  const storageKey = (id: string) => `${NS}:quiz:${id}`;

  document.querySelectorAll<HTMLFormElement>('[data-quiz]').forEach((form) => {
    if (form.dataset.enhanced) return;
    form.dataset.enhanced = 'true';

    const id = form.dataset.quizId ?? '';
    const correct = Number(form.dataset.correct);
    const radios = Array.from(form.querySelectorAll<HTMLInputElement>('input[type="radio"]'));
    const whyTpl = form.querySelector<HTMLTemplateElement>('template[data-quiz-why]');
    const whyText = (whyTpl?.content.textContent ?? whyTpl?.textContent ?? '').trim();
    if (radios.length === 0) return;

    // Check button + live-region feedback.
    const actions = document.createElement('div');
    actions.className = 'quiz__actions';
    const check = document.createElement('button');
    check.type = 'button';
    check.className = 'quiz__check';
    check.textContent = 'Check answer';
    check.disabled = true;
    actions.appendChild(check);

    const feedback = document.createElement('p');
    feedback.className = 'quiz__feedback';
    feedback.setAttribute('role', 'status');
    feedback.hidden = true;

    form.append(actions, feedback);

    radios.forEach((r) =>
      r.addEventListener('change', () => {
        check.disabled = false;
      })
    );

    function reveal(selected: number, persist: boolean) {
      const ok = isAnswerCorrect(selected, correct);
      radios.forEach((r, i) => {
        const li = r.closest('li');
        li?.classList.toggle('is-correct', i === correct);
        li?.classList.toggle('is-wrong', i === selected && !ok);
      });
      feedback.hidden = false;
      feedback.classList.toggle('is-ok', ok);
      feedback.textContent = quizFeedback(selected, correct, whyText);
      form.dataset.answered = String(selected);
      if (persist) {
        try {
          localStorage.setItem(storageKey(id), String(selected));
        } catch {
          /* storage may be unavailable (private mode) — degrade silently */
        }
      }
    }

    check.addEventListener('click', () => {
      const selected = radios.findIndex((r) => r.checked);
      if (selected < 0) return;
      reveal(selected, true);
    });

    // Restore prior answer.
    try {
      const saved = localStorage.getItem(storageKey(id));
      if (saved !== null && radios[Number(saved)]) {
        radios[Number(saved)].checked = true;
        check.disabled = false;
        reveal(Number(saved), false);
      }
    } catch {
      /* ignore */
    }
  });
</script>

<style is:global>
  .quiz__actions {
    margin-top: var(--space-4);
  }

  .quiz__check {
    border: 0;
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-5);
    background: var(--gradient-brand);
    color: var(--brand-contrast);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(204, 0, 0, 0.15);
    transition: transform var(--transition-spring), box-shadow var(--transition-smooth), background var(--transition-smooth);
  }

  .quiz__check:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(204, 0, 0, 0.22);
  }

  .quiz__check:active:not(:disabled) {
    transform: translateY(0);
  }

  .quiz__check:disabled {
    background: var(--gray-300);
    color: var(--gray-600);
    box-shadow: none;
    cursor: not-allowed;
  }

  .quiz__feedback {
    margin: var(--space-4) 0 0;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid rgba(204, 0, 0, 0.2);
    background: rgba(204, 0, 0, 0.04);
    color: #8a0000;
    font-size: var(--fs-sm);
    line-height: var(--lh-base);
    
    /* Reveal transitions */
    display: block;
    opacity: 1;
    transform: scale(1);
    transition: opacity 300ms ease, transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1), display 300ms allow-discrete;
  }

  .quiz__feedback[hidden] {
    display: none !important;
    opacity: 0;
    transform: scale(0.95);
  }

  @starting-style {
    .quiz__feedback {
      opacity: 0;
      transform: scale(0.95);
    }
  }

  .quiz__feedback.is-ok {
    background: rgba(47, 158, 88, 0.04);
    border-color: rgba(47, 158, 88, 0.2);
    color: #11633a;
  }

  .quiz li.is-correct label {
    border-color: #2f9e58 !important;
    background: rgba(47, 158, 88, 0.06) !important;
    box-shadow: 0 0 10px rgba(47, 158, 88, 0.1);
    transform: scale(1.01);
  }

  .quiz li.is-wrong label {
    border-color: #cc0000 !important;
    background: rgba(204, 0, 0, 0.06) !important;
    box-shadow: 0 0 10px rgba(204, 0, 0, 0.1);
    transform: scale(0.99);
    opacity: 0.9;
  }
</style>
