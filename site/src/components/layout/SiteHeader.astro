---
import { getCollection, getEntry } from 'astro:content';
import { href, weekUrl, deckUrl } from '@lib/url';
import Icon from '@components/Icon.astro';
import type { IconName } from '@lib/icons';

interface Props {
  activeWeekId?: string;
  activeDeckId?: string;
}

const { activeWeekId, activeDeckId } = Astro.props;

// Fetch course configuration
const courseEntry = await getEntry('course', 'course');
const course = courseEntry!.data;

// Fetch and sort weeks according to course.weekOrder
const allWeeks = await getCollection('weeks');
const weeks = course.weekOrder
  .map((ref) => allWeeks.find((w) => w.id === ref.id))
  .filter((w): w is NonNullable<typeof w> => !!w);

// Fetch the active week and its decks
const activeWeek = activeWeekId ? weeks.find((w) => w.id === activeWeekId) : null;
const allDecks = await getCollection('decks');
const activeWeekDecks = activeWeek
  ? allDecks
      .filter((d) => d.data.week.id === activeWeek.id)
      .sort((a, b) => a.id.localeCompare(b.id))
  : [];

// Week icon/label helper mapping
function getWeekMeta(number: number): { label: string; icon: IconName } {
  const meta: Record<number, { label: string; icon: IconName }> = {
    1: { label: 'Intro', icon: 'playCircle' },
    2: { label: 'Data', icon: 'grid' },
    3: { label: 'DBs', icon: 'database' },
    4: { label: 'Viz', icon: 'chart' },
    5: { label: 'EDA', icon: 'tools' },
    6: { label: 'Pipeline', icon: 'terminal' },
    7: { label: 'Text', icon: 'document' },
    8: { label: 'Analytics', icon: 'clipboard' },
    9: { label: 'Regression', icon: 'trend' },
    10: { label: 'Classification', icon: 'gitMerge' },
    11: { label: 'Clustering', icon: 'bubble' },
    12: { label: 'AI', icon: 'sparkles' },
    13: { label: 'Project', icon: 'award' },
  };
  return meta[number] || { label: `Week ${number}`, icon: 'book' };
}
---

<header class="site-header">
  {/* First Row: Logo, Week Scroll Nav, Actions */}
  <div class="row-top">
    <div class="row-top__content">
      {/* Week Selector Navbar */}
      <div class="week-nav-wrapper">
        <button class="nav-arrow nav-arrow--left" aria-label="Scroll left">
          <Icon name="chevronLeft" size={16} />
        </button>

        <nav class="week-nav-scroll" aria-label="Week navigation">
          {weeks.map((week) => {
            const { label, icon } = getWeekMeta(week.data.number);
            const isActive = activeWeekId === week.id;
            return (
              <a
                href={weekUrl(week.id)}
                class:list={['week-nav-item', { 'is-active': isActive }]}
                title={`Week ${week.data.number}: ${week.data.title}`}
              >
                <span class="week-nav-item__icon">
                  <Icon name={icon} size={20} />
                </span>
                <span class="week-nav-item__label">{label}</span>
              </a>
            );
          })}
        </nav>

        <button class="nav-arrow nav-arrow--right" aria-label="Scroll right">
          <Icon name="chevronRight" size={16} />
        </button>
      </div>
    </div>
  </div>

  {/* Second Row: Content Tabs (only rendered when viewing a week/deck) */}
  {activeWeek && (
    <div class="row-bottom">
      <div class="row-bottom__content">
        <div class="active-week-info">
          <span class="active-week-info__title">
            WEEK {activeWeek.data.number}: {activeWeek.data.title.toUpperCase()}
          </span>
        </div>

        <nav class="content-tabs" aria-label="Content navigation">
          {/* Overview Tab */}
          <a
            href={weekUrl(activeWeek.id)}
            class:list={['tab-item', { 'is-active': !activeDeckId }]}
          >
            <Icon name="info" size={18} />
            <span class="tab-item__label">Overview</span>
          </a>

          {/* Slide Deck Tabs */}
          {activeWeekDecks.map((deck) => {
            const isActive = activeDeckId === deck.id;
            return (
              <a
                href={deckUrl(deck)}
                class:list={['tab-item', { 'is-active': isActive }]}
                title={deck.data.title}
              >
                <Icon name="slides" size={18} />
                <span class="tab-item__label">{deck.data.title}</span>
              </a>
            );
          })}
        </nav>
      </div>
    </div>
  )}
</header>

<style>
  :root {
    --header-accent-blue: #1e40af;
    --header-border-color: #e2e8f0;
  }

  .site-header {
    background: #ffffff;
    border-bottom: 1px solid var(--header-border-color);
    width: 100%;
    display: flex;
    flex-direction: column;
    z-index: 50;
  }

  /* First Row Styling */
  .row-top {
    border-bottom: 1px solid var(--header-border-color);
    padding: var(--space-2) var(--space-4);
  }

  .row-top__content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    max-width: 100%;
    width: 100%;
    margin: 0 auto;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--ink);
    flex-shrink: 0;
  }

  .brand__mark {
    display: grid;
    place-items: center;
    width: 1.85rem;
    height: 1.85rem;
    border-radius: var(--radius-sm);
    background: var(--brand);
    color: var(--brand-contrast);
    font-weight: 800;
    font-size: var(--fs-base);
    line-height: 1;
  }

  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand__text strong {
    font-size: var(--fs-sm);
    font-weight: 700;
  }

  .brand__school {
    font-size: var(--fs-xs);
    color: var(--ink-muted);
  }

  @media (max-width: 640px) {
    .brand__school {
      display: none;
    }
  }

  /* Week scroll selector navigation */
  .week-nav-wrapper {
    display: flex;
    align-items: center;
    flex-grow: 1;
    max-width: 80rem;
    position: relative;
    width: 100%;
  }

  .week-nav-scroll {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    flex: 1;
    padding: 0 var(--space-2);
  }

  .week-nav-scroll::-webkit-scrollbar {
    display: none;
  }

  .nav-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: 0;
    background: transparent;
    color: var(--ink-muted);
    cursor: pointer;
    border-radius: 50%;
    transition: background var(--transition), color var(--transition);
  }

  .nav-arrow:hover {
    background: var(--surface-muted);
    color: var(--ink);
  }

  .week-nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--ink-muted);
    padding: var(--space-1) var(--space-3);
    min-width: 5.5rem;
    border-bottom: 2px solid transparent;
    transition: all var(--transition);
  }

  .week-nav-item:hover {
    color: var(--ink);
  }

  .week-nav-item.is-active {
    color: var(--header-accent-blue);
    border-bottom-color: var(--header-accent-blue);
    font-weight: 600;
  }

  .week-nav-item__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 1.5rem;
  }

  .week-nav-item__label {
    font-size: 0.75rem;
    font-weight: 500;
    margin-top: 2px;
    white-space: nowrap;
  }

  /* Header actions on right */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 0;
    background: transparent;
    color: var(--ink-muted);
    cursor: pointer;
    border-radius: 50%;
    transition: background var(--transition), color var(--transition);
  }

  .action-btn:hover {
    background: var(--surface-muted);
    color: var(--ink);
  }

  .user-avatar {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--gray-100);
    border: 1px solid var(--border);
    color: var(--gray-600);
    cursor: pointer;
    transition: border-color var(--transition);
  }

  .user-avatar:hover {
    border-color: var(--header-accent-blue);
  }

  /* Second Row Styling */
  .row-bottom {
    background: #f8fafc;
    padding: 0 var(--space-4);
  }

  .row-bottom__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    max-width: 90rem;
    width: 100%;
    margin: 0 auto;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .row-bottom__content::-webkit-scrollbar {
    display: none;
  }

  .active-week-info {
    font-size: var(--fs-base);
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.01em;
    padding: var(--space-3) 0;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .active-week-info__title {
    color: var(--header-accent-blue);
  }

  .content-tabs {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .tab-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--ink-muted);
    padding: var(--space-3) var(--space-2);
    border-bottom: 2px solid transparent;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .tab-item:hover {
    color: var(--ink);
  }

  .tab-item.is-active {
    color: var(--header-accent-blue);
    border-bottom-color: var(--header-accent-blue);
    font-weight: 600;
  }

  .tab-item :global(svg) {
    opacity: 0.7;
    transition: opacity var(--transition);
  }

  .tab-item.is-active :global(svg) {
    opacity: 1;
    color: var(--header-accent-blue);
  }

  @media (max-width: 768px) {
    .row-bottom__content {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: var(--space-2) 0;
    }

    .active-week-info {
      padding: var(--space-1) 0;
    }

    .content-tabs {
      width: 100%;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .content-tabs::-webkit-scrollbar {
      display: none;
    }
  }
</style>

<script>
  // Dynamic horizontal scrolling behavior for week navigation
  const scrollNav = () => {
    const nav = document.querySelector('.week-nav-scroll');
    const leftArrow = document.querySelector('.nav-arrow--left');
    const rightArrow = document.querySelector('.nav-arrow--right');

    if (nav && leftArrow && rightArrow) {
      leftArrow.addEventListener('click', () => {
        nav.scrollBy({ left: -240, behavior: 'smooth' });
      });

      rightArrow.addEventListener('click', () => {
        nav.scrollBy({ left: 240, behavior: 'smooth' });
      });

      // Update visibility of arrows based on scroll position
      const toggleArrows = () => {
        const scrollLeft = nav.scrollLeft;
        const maxScroll = nav.scrollWidth - nav.clientWidth;

        leftArrow.classList.toggle('is-disabled', scrollLeft <= 0);
        rightArrow.classList.toggle('is-disabled', scrollLeft >= maxScroll - 1);
      };

      nav.addEventListener('scroll', toggleArrows);
      window.addEventListener('resize', toggleArrows);
      
      // Run once on load
      toggleArrows();

      // Scroll active week into view
      const activeItem = nav.querySelector('.week-nav-item.is-active') as HTMLElement | null;
      if (activeItem) {
        const offset = activeItem.offsetLeft - (nav.clientWidth / 2) + (activeItem.clientWidth / 2);
        nav.scrollTo({ left: offset, behavior: 'auto' });
      }
    }
  };

  // Run initial hookup
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', scrollNav);
  } else {
    scrollNav();
  }
</script>
